  },
  "ingredients": [
    {
      "item": "butter",
      "amount": "2 tbsp."
    },
    {
      "item": "small onion, minced",
      "amount": "1"
    },
    {
      "item": "cooked ham, julienned",
      "amount": "1/2 lb."
    },
    {
      "item": "tiny peas, cooked",
      "amount": "1/2 lb."
    },
    {
      "item": "small new potatoes, peeled, cooked, and halved",
      "amount": "4 to 6"
    },
    {
      "item": "pesto sauce",
      "amount": "1 cup"
    },
    {
      "item": "fettuccine",
      "amount": "1 lb."
    },
    {
      "item": "Parmesan cheese",
      "amount": ""
    }
  ],
  "method": [
    "Melt butter in a large skillet and sauté onion over medium heat for 5 minutes. Add ham, peas, potatoes and pesto",
    "sauce to skillet; heat through.",
    "Cook fettuccine according to package directions; drain. Place hot pasta in a large, heated serving bowl.",
    "Add the potato-pesto mixture and toss gently to mix. Sprinkle with Parmesan cheese and serve."
  ],
