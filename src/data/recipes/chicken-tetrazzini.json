{
  "id": "chicken-tetrazzini",
  "name": "Chicken Tetrazzini",
  "source": {
    "cookbook": "The Best Pasta Recipes",
    "author": "Jaydon Mack"
  },
  "servings": "serves 8",
  "ingredients": [
    {
      "item": "spaghetti",
      "amount": "8 oz."
    },
    {
      "item": "olive oil",
      "amount": "1 tbsp."
    },
    {
      "item": "shredded chicken breasts",
      "amount": "4"
    },
    {
      "item": "Salt and pepper to taste",
      "amount": ""
    },
    {
      "item": "fresh sliced mushrooms",
      "amount": "1 cup"
    },
    {
      "item": "chopped red bell pepper",
      "amount": "1"
    },
    {
      "item": "chopped onion",
      "amount": "1"
    },
    {
      "item": "minced garlic cloves",
      "amount": "4"
    },
    {
      "item": "butter",
      "amount": "¼ cup"
    },
    {
      "item": "flour",
      "amount": "3 tbsp."
    },
    {
      "item": "thyme",
      "amount": "½ tsp."
    },
    {
      "item": "chicken broth",
      "amount": "1 cup"
    },
    {
      "item": "half-and-half",
      "amount": "1 cup"
    },
    {
      "item": "white wine",
      "amount": "¼ cup"
    },
    {
      "item": "garlic salt",
      "amount": "½ tsp."
    },
    {
      "item": "oregano",
      "amount": "½ tsp."
    },
    {
      "item": "Pepper to taste",
      "amount": ""
    },
    {
      "item": "shredded Italian cheese mix",
      "amount": "½ cup"
    }
  ],
  "method": [
    "Cook the spaghetti in a pot of boiling salted water for 10 minutes.",
    "Heat the oil in a large skillet.",
    "Brown the bell pepper, mushrooms, onion, and garlic into the skillet and sauté for 5 minutes, until the vegetables are soft and the chicken no longer pink.",
    "Melt the butter in a pan and stir in the flour.",
    "Keep stirring until a paste is created.",
    "Slowly pour in the broth, half-and-half, and wine while continuously stirring.",
    "Season the sauce with pepper, oregano, and thyme.",
    "Stir in the Italian cheese blend and stir for 5 minutes, until the cheese is melted.",
    "Add the browned and vegetables and simmer for 5 minutes."
  ],
