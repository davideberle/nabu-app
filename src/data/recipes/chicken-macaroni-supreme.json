      "amount": "1/4 tsp."
    },
    {
      "item": "chicken flavor bouillon granules",
      "amount": "2 tsp."
    },
    {
      "item": "frozen peas, thawed",
      "amount": "1/2 cup"
    },
    {
      "item": "low fat milk",
      "amount": "1 cup"
    },
    {
      "item": "flour",
      "amount": "1 tbsp."
    },
    {
      "item": "American cheese, shredded",
      "amount": "1 1/2 cups"
    }
