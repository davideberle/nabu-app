{
  "id": "curry-pineapple-fried-rice",
  "name": "Curry Pineapple Fried Rice",
  "source": {
    "cookbook": "The Complete and Authentic Thai Curry Cookbook 2",
    "author": "Various",
    "chapter": "Thai Curries"
  },
  "servings": "serves 6",
  "ingredients": [
    {
      "item": "uncooked white rice",
      "amount": "1 - ½ cups"
    },
    {
      "item": "water",
      "amount": "3 cups"
    },
    {
      "item": "red curry paste",
      "amount": "1 tbsp."
    },
    {
      "item": "garlic, minced",
      "amount": "2 cloves"
    },
    {
      "item": "red bell pepper, chopped",
      "amount": "1"
    },
    {
      "item": "pineapple",
      "amount": "1"
    },
    {
      "item": "onion, diced",
      "amount": "1"
    },
    {
      "item": "boneless chicken meat",
      "amount": "1 pound"
    },
    {
      "item": "Asian fish sauce",
      "amount": "2 tbsp."
    },
    {
      "item": "vegetable oil",
      "amount": "1 tbsp."
    },
    {
      "item": "green onions, chopped",
      "amount": "1/4 cup"
    }
  ],
  "method": [
    "In a saucepan, bring water to a boil. Add rice and Let simmer until rice is",
    "cooked.",
    "Oil and heat the skillet. Add garlic and onion and cook until translucent.",
    "Add in chicken and cook for 10 minutes or until chicken is no longer pink.",
    "Stir in rice, pineapple, fish sauce, bell pepper, and curry paste. Mix well and",
    "cook uncovered for another 10 - 15 minutes. Sprinkle over with green",
    "onions and serve."
  ],
  "time": {
    "total": 30
  },
