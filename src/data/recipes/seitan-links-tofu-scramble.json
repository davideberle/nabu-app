{
  "id": "seitan-links-tofu-scramble",
  "name": "Seitan Links Tofu Scramble",
  "source": {
    "cookbook": "The High-Protein Vegan Cookbook",
    "author": "Ginny Kay McMeans"
  },
  "servings": "",
  "ingredients": [
    {
      "item": "dairy-free butter",
      "amount": "1 tbsp"
    },
    {
      "item": "diced onion",
      "amount": "½ cup"
    },
    {
      "item": "mushrooms, sliced",
      "amount": "8 ounces"
    },
    {
      "item": "extra-firm tofu, drained, pressed (page 17), and crumbled",
      "amount": "16 ounces"
    },
    {
      "item": "Slow Cooker Maple Breakfast Links, sliced thick (page 276)",
      "amount": "8 ounces"
    },
    {
      "item": "15-ounce can black beans, drained and rinsed",
      "amount": "1"
    },
    {
      "item": "nutritional yeast",
      "amount": "2 tbsp"
    },
    {
      "item": "chili powder",
      "amount": "½ tsp"
    },
    {
      "item": "paprika",
      "amount": "½ tsp"
    },
    {
      "item": "black salt",
      "amount": "½ tsp"
    },
    {
      "item": "turmeric",
      "amount": "½ tsp"
    },
    {
      "item": "garlic powder",
      "amount": "¼ tsp"
    }
  ],
  "method": [
    "Heat the butter over medium-high heat in a large skillet. Add the onion, mushrooms, tofu, and seitan links. Sauté 15 minutes.",
    "Add the black beans, nutritional yeast, and all the spices and seasonings. Heat through 5 minutes and serve."
  ],
