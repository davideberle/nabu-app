  "ingredients": [
    {
      "item": "butter",
      "amount": "2 tbsp."
    },
    {
      "item": "onion, chopped",
      "amount": "1/2 cup"
    },
    {
      "item": "shallot, minced",
      "amount": "1 tbsp."
    },
    {
      "item": "bacon or Pancetta, chopped",
      "amount": "1/4 lb."
    },
    {
      "item": "dry white wine",
      "amount": "1/4 cup"
    },
    {
      "item": "eggs, beaten",
      "amount": "3"
    },
    {
      "item": "freshly grated parmesan cheese",
      "amount": "1/2 cup"
    },
    {
      "item": "pepper",
      "amount": "1/2 tsp."
    },
    {
      "item": "chopped fresh parsley",
      "amount": "2 tbsp."
    },
    {
      "item": "linguine",
      "amount": "1 lb."
    }
