  "method": [
    "Preheat oven to 350ºF.",
    "Put the chicken in a pan. Add olive oil and chili powder, cumin, salt,",
    "and a pinch of cayenne in it.",
    "Roast them for half an hour. Shred the chicken pieces and set aside.",
    "Take a pot and heat the remaining olive oil. Put garlic and onion, and",
    "cook for 5 minutes.",
    "Add shredded chicken, beans, oregano, chilies, chile powder, cumin,",
    "salt, and cayenne.",
    "Add chicken broth.",
    "Stir and simmer for 20 minutes on low heat.",
    "Remove the pan from heat and set aside for 5 minutes.",
    "Add cheese to the pot, and stir in sour cream.",
    "Bring the pan back to simmer on low heat.",
    "Cook chili for another 15-20 minutes. Add texture by using a",
    "masher to mash beans and the chicken.",
    "Stir to mix everything.",
    "Garnish and serve."
