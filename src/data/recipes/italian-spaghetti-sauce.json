      "item": "garlic, minced",
      "amount": "1 clove"
    },
    {
      "item": "vegetable or olive oil",
      "amount": "3 tbsp."
    },
    {
      "item": "cans, or 4 cups tomatoes, cut up",
      "amount": "2 (1 lb. each)"
    },
    {
      "item": "tomato paste",
      "amount": "2 (6 oz. each)"
    },
    {
      "item": "water",
      "amount": "2 cups"
    },
    {
      "item": "brown sugar",
      "amount": "1 tsp."
    },
    {
      "item": "salt",
      "amount": "1 ½ tsp."
    },
    {
      "item": "dried oregano",
      "amount": "1 ½ tsp."
    },
    {
      "item": "bay leaf",
      "amount": "1"
    },
    {
      "item": "pkg. spaghetti",
      "amount": "1 (16 oz.)"
    },
    {
      "item": "black pepper",
      "amount": "½ tsp."
    }
