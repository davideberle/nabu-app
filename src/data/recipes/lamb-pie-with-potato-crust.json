    },
    {
      "item": "large Spanish onion, sliced",
      "amount": "1"
    },
    {
      "item": "cloves garlic, crushed",
      "amount": "2"
    },
    {
      "item": "carrots, diced",
      "amount": "2"
    },
    {
      "item": "stalks celery, diced",
      "amount": "3"
    },
    {
      "item": "parsnip, diced",
      "amount": "1"
    },
    {
      "item": "sprigs fresh rosemary",
      "amount": "2"
    },
    {
      "item": "fresh sage leaves",
      "amount": "10"
    },
    {
      "item": "thickly sliced leg ham, cut into thin strips",
      "amount": "200 g"
    },
    {
      "item": "red wine",
      "amount": "350 ml"
    },
    {
      "item": "organic egg",
      "amount": "1"
    },
    {
      "item": "cream",
      "amount": "2 tablespoons"
    }
