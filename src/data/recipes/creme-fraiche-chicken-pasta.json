  "method": [
    "Heat the oil in a large skillet.",
    "Brown the chicken for 5 minutes.",
    "Pour in the wine and broth and season with salt and pepper.",
    "Simmer for 20 minutes.",
    "While the chicken is simmering, cook the pasta in a pot of salted water for 10 minutes and drain. Set aside.",
    "Use a tong to transfer the chicken to a platter and cube the chicken.",
    "Add the onion, garlic, and mushrooms to the skillet and sauté for 5 minutes.",
    "Return the cubed chicken to the skillet and stir in the crème fraiche.",
    "Simmer for 5 minutes.",
    "Place the pasta in a serving bowl and pour the sauce over the pasta.",
    "Top with parmesan cheese and chopped parsley."
