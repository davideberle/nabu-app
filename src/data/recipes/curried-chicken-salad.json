  "ingredients": [
    {
      "item": "of skinless, boneless grilled chicken, chopped",
      "amount": "2 cups"
    },
    {
      "item": "small apple, diced",
      "amount": "1"
    },
    {
      "item": "of celery ribs, diced",
      "amount": "½ cup"
    },
    {
      "item": "of green olives from a jar",
      "amount": "½ cup"
    },
    {
      "item": "of mayonnaise",
      "amount": "½ cup"
    },
    {
      "item": "of curry powder",
      "amount": "1 tsp."
    },
    {
      "item": "of raisins",
      "amount": "3 tbsp."
    }
  ],
  "method": [
    "Combine mayonnaise and curry powder in a medium bowl, stirring until",
    "very well blended.",
    "Add the grilled chicken, the apple, celery, raisins, olives and then stir the",
    "salad again. Cover and chill."
  ],
