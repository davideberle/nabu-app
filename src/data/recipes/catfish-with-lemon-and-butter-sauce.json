{
  "id": "catfish-with-lemon-and-butter-sauce",
  "name": "Catfish with Lemon and Butter Sauce",
  "source": {
    "cookbook": "More Than Carbonara",
    "author": "Various",
    "chapter": "Seafood Pasta Recipes"
  },
  "servings": "serves 8",
  "ingredients": [
    {
      "item": "butter",
      "amount": "¾ cup"
    },
    {
      "item": "package (9 oz). spaghetti",
      "amount": "1"
    },
    {
      "item": "garlic clove, minced",
      "amount": "1"
    },
    {
      "item": "fresh mushrooms, sliced",
      "amount": "8 oz."
    },
    {
      "item": "salt",
      "amount": "1 tsp."
    },
    {
      "item": "black pepper",
      "amount": "1/2 tsp."
    },
    {
      "item": "chicken broth",
      "amount": "1/2 cup"
    },
    {
      "item": "lemon juice",
      "amount": "2 tsp."
    },
    {
      "item": "chopped fresh parsley",
      "amount": "1/4 cup"
    },
    {
      "item": "catfish fillets, cut into 1-inch pieces",
      "amount": "1 1/2 lb."
    },
    {
      "item": "Parmesan cheese",
      "amount": "1/2 cup"
    }
  ],
  "method": [
    "Cook spaghetti as per the directions on the package and drain.",
    "Over medium heat, melt butter in a large skillet. Cook garlic and mushrooms for 5 minutes, stirring occasionally.",
    "Add salt, pepper, broth, lemon juice and parsley. Cook 3 minutes, stirring occasionally.",
    "Leave skillet uncovered, add catfish and simmer until fish flakes easily with fork, about 6 to 8 minutes. Sauce will",
    "be thin. Serve over spaghetti and sprinkle with Parmesan cheese. If desired, garnish with parsley and lemon pieces."
  ],
