{
  "id": "tamarind-chutney",
  "name": "TAMARIND CHUTNEY",
  "source": {
    "cookbook": "The Curry Guy Bible",
    "author": "Dan Toombs"
  },
  "servings": "makes 2 jars",
  "intro": "Tamarind chutney simply has to be on the table when my wife and I plan a curry party. It’s sweet, sour, savoury and spicy, and also has a nice crunch to it. What more could you ask for in a chutney?",
  "ingredients": [
    {
      "item": "tamarind concentrate",
      "amount": "1–2 tbsp"
    },
    {
      "item": "water",
      "amount": "2 tbsp"
    },
    {
      "item": "sugar",
      "amount": "3 tbsp"
    },
    {
      "item": "tomato ketchup",
      "amount": "4 tbsp"
    },
    {
      "item": "Juice of 1 lemon",
      "amount": ""
    },
    {
      "item": "fresh green chillies, finely chopped",
      "amount": "3"
    },
    {
      "item": "onion, finely chopped",
      "amount": "½"
    },
    {
      "item": "spring onions (scallions), finely chopped",
      "amount": "3"
    },
    {
      "item": "finely chopped coriander (cilantro)",
      "amount": "4 tbsp"
    },
    {
      "item": "large carrot, grated",
      "amount": "1"
    },
    {
      "item": "madras curry powder",
      "amount": "1 tsp"
    },
    {
      "item": "Salt, to taste",
      "amount": ""
    }
  ],
  "method": [
    "Put all the ingredients into a small bowl and mix well. Refrigerate for at least 1 hour before serving."
  ],
  "dietary": [
    "vegan",
    "vegetarian"
  ]
}