      "amount": "1"
    },
    {
      "item": "carrots, peeled and diagonally sliced",
      "amount": "4"
    },
    {
      "item": "fried tofu cubes",
      "amount": "1 lb."
    },
    {
      "item": "vegetable broth",
      "amount": "2 cups"
    },
    {
