      "amount": "400 g"
    },
    {
      "item": "small red chilli, finely sliced",
      "amount": "1"
    },
    {
      "item": "blue swimmer crab",
      "amount": "1"
    },
    {
      "item": "saffron powder",
      "amount": "½ teaspoon"
    },
    {
      "item": "good-quality couscous",
      "amount": "500 g"
    }
  ],
  "method": [
    "Heat the reserved fish stock in a separate saucepan. Stir in the saffron powder then add the couscous. Add the remaining oil, stir well and leave to absorb (as per the packet instructions). Fluff the couscous up with a fork, adding a little more oil if need be. Tip the couscous out onto a warm serving plate and ladle on some of the fish stew. Serve the remaining fish stew on the side."
  ]
