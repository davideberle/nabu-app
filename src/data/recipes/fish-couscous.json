      "amount": "60 ml"
    },
    {
      "item": "large Spanish onion, finely chopped",
      "amount": "1"
    },
    {
      "item": "cloves garlic, sliced",
      "amount": "3"
    },
    {
      "item": "fresh bay leaves",
      "amount": "3"
    },
