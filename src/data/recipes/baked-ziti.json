    },
    {
      "item": "Salt and pepper to taste",
      "amount": ""
    },
    {
      "item": "garlic salt",
      "amount": "½ tsp."
    },
    {
      "item": "garlic powder",
      "amount": "½ tsp."
    },
    {
      "item": "chopped onion",
      "amount": "1"
    },
    {
      "item": "tomato sauce",
      "amount": "6 cups"
    },
    {
