    },
    {
      "item": "thyme",
      "amount": "1 teaspoon"
    },
    {
      "item": "oregano",
      "amount": "1 teaspoon"
    },
    {
      "item": "cayenne pepper",
      "amount": "½ teaspoon"
    },
    {
