{
  "id": "spinach-lasagna",
  "name": "Spinach Lasagna",
  "source": {
    "cookbook": "The Best Pasta Recipes",
    "author": "Jaydon Mack"
  },
  "servings": "serves 8",
  "ingredients": [
    {
      "item": "olive oil",
      "amount": "1 tbsp."
    },
    {
      "item": "chopped frozen spinach",
      "amount": "10 oz."
    },
    {
      "item": "small, chopped onion",
      "amount": "1"
    },
    {
      "item": "sliced mushrooms",
      "amount": "1 cup"
    },
    {
      "item": "grated parmesan cheese",
      "amount": "¼ cup"
    },
    {
      "item": "minced garlic cloves",
      "amount": "3"
    },
    {
      "item": "Italian seasoning",
      "amount": "¾ tsp."
    },
    {
      "item": "shredded mozzarella cheese",
      "amount": "12 oz."
    },
    {
      "item": "of marinara sauce-preferably homemade",
      "amount": "4 cups"
    },
    {
      "item": "ricotta cheese",
      "amount": "2 cups"
    },
    {
      "item": "beaten eggs",
      "amount": "2"
    },
    {
      "item": "Salt and pepper to taste",
      "amount": ""
    },
    {
      "item": "cooked lasagna noodles",
      "amount": "10 oz."
    }
  ],
  "method": [
    "Preheat the oven to 350 degrees.",
    "Heat the olive oil in a large pot.",
    "Sauté the spinach, onion, mushrooms, garlic, and Italian seasoning for 5 minutes.",
    "Cover with the marinara sauce and simmer for 30 minutes.",
    "Combine the ricotta cheese, mozzarella cheese, parmesan cheese, and the eggs in a bowl.",
    "Season with salt and pepper.",
    "Pour 1 cup of sauce in the bottom of a lasagna pan.",
    "Top with 4 noodles, half the remaining cheese and half the sauce.",
    "Repeat the layering and end with the sauce.",
    "Cover the pan with aluminum and bake for 55 minutes.",
    "Remove the aluminum and cook for 15 more minutes."
  ],
